DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=25

# 博查 Web Search（联网查询工具）。留空则不启用联网搜索，Agent 回落到本地逻辑。
# 到 https://open.bochaai.com 注册并在「API KEY 管理」创建 key（形如 sk-xxxx）。
BOCHA_API_KEY=
BOCHA_BASE_URL=https://api.bochaai.com
WEB_SEARCH_TIMEOUT_SECONDS=20
# 联网搜索结果缓存时长（秒），默认 6 小时。
WEB_SEARCH_CACHE_TTL_SECONDS=21600
# 单轮对话里 Agent 调用工具的最大轮数上限（护栏，防止死循环/烧钱）。
AGENT_MAX_TOOL_ROUNDS=4