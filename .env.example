# DeepSeek LLM
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=25

# 博查 Web Search（联网查询工具）。留空则不启用联网搜索，Agent 回落到本地逻辑。
# 到 https://open.bochaai.com 注册并在「API KEY 管理」创建 key（形如 sk-xxxx）。
BOCHA_API_KEY=
BOCHA_BASE_URL=https://api.bochaai.com
WEB_SEARCH_TIMEOUT_SECONDS=20
# 联网搜索结果缓存时长（秒），默认 6 小时。
WEB_SEARCH_CACHE_TTL_SECONDS=21600
# 单轮对话里 Agent 调用工具的最大轮数上限（护栏，防止死循环/烧钱）。
AGENT_MAX_TOOL_ROUNDS=4

# Langfuse Tracing（留空则不启用 tracing）
# docker-compose.yml 中已通过 LANGFUSE_INIT_* 自动创建项目和用户，
# 下方 Public/Secret Key 与 docker-compose 中的预配置值一致，复制后无需修改。
# 如需自定义，登录 http://localhost:3000 创建新项目后替换。
LANGFUSE_PUBLIC_KEY=pk-lf-init
LANGFUSE_SECRET_KEY=sk-lf-init
# Docker Compose 部署时保持此值（容器间内网通信）；
# 仅当 app 在容器外运行时才改为 http://localhost:3000
LANGFUSE_HOST=http://langfuse-web:3000

# DashScope（RAG 知识库 Embedding + Reranker）
# 到 https://dashscope.console.aliyun.com 注册并创建 API Key（同时用于 embedding 和 rerank）
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_RERANK_MODEL=gte-rerank
EMBEDDING_DIMENSIONS=1024
# RAG 复用 Langfuse 的 Postgres（pgvector 扩展已自动创建）
RAG_DATABASE_URL=postgresql://langfuse:langfuse@postgres:5432/langfuse
